<mujoco model="walker2d">
    <compiler angle="degree"  inertiafromgeom="true"/>
    <option timestep="0.002" iterations="50" solver="Newton" gravity="0 0 -9.81">
        <flag warmstart="enable"/>
    </option>
    <default>
        <joint armature="0.01" damping="0.1" limited="true"/>
        <geom conaffinity="1" contype="1" condim="3" density="1000" friction="0.8 0.1 0.1" 
              margin="0.001" material="geom" rgba="0.8 0.6 0.4 1"/>
        <motor ctrllimited="true" ctrlrange="-1 1"/>
    </default>
    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512"/>
        <material name="MatPlane" texture="texplane" texrepeat="1 1" texuniform="true" reflectance="0.5"/>
        <material name="geom" rgba="0.8 0.6 0.4 1"/>
    </asset>
    <worldbody>
        <light directional="true" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" pos="0 0 5" dir="0 0 -1"/>
        <geom name="floor" type="plane" pos="0 0 0" size="40 40 40" material="MatPlane" rgba="0.8 0.9 0.8 1" contype="1" conaffinity="1"/>
        
        <!-- 躯干 -->
        <body name="torso" pos="0 0 1.25">
            <camera name="track" pos="0 -3 1" xyaxes="1 0 0 0 0 1" mode="trackcom"/>
            <joint name="rootx" type="slide" pos="0 0 0" axis="1 0 0" limited="false"/>
            <joint name="rootz" type="slide" pos="0 0 0" axis="0 0 1" limited="false"/>
            <joint name="rooty" type="hinge" pos="0 0 0" axis="0 1 0" limited="false"/>
            <geom name="torso_geom" type="capsule" fromto="0 0 0.2 0 0 -0.2" size="0.05"/>
            
            <!-- 右腿 -->
            <body name="thigh" pos="0 0 -0.2">
                <joint name="thigh_joint" type="hinge" pos="0 0 0" axis="0 -1 0" range="-120 60"/>
                <geom name="thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.45" size="0.05"/>
                <body name="leg" pos="0 0 -0.45">
                    <joint name="leg_joint" type="hinge" pos="0 0 0" axis="0 -1 0" range="-120 60"/>
                    <geom name="leg_geom" type="capsule" fromto="0 0 0 0 0 -0.5" size="0.04"/>
                    <body name="foot" pos="0 0 -0.5">
                        <joint name="foot_joint" type="hinge" pos="0 0 0" axis="0 -1 0" range="-45 45"/>
                        <geom name="foot_geom" type="capsule" fromto="-0.1 0 0 0.2 0 0" size="0.06"/>
                    </body>
                </body>
            </body>
            
            <!-- 左腿 -->
            <body name="thigh_left" pos="0 0 -0.2">
                <joint name="thigh_left_joint" type="hinge" pos="0 0 0" axis="0 -1 0" range="-120 60"/>
                <geom name="thigh_left_geom" type="capsule" fromto="0 0 0 0 0 -0.45" size="0.05"/>
                <body name="leg_left" pos="0 0 -0.45">
                    <joint name="leg_left_joint" type="hinge" pos="0 0 0" axis="0 -1 0" range="-120 60"/>
                    <geom name="leg_left_geom" type="capsule" fromto="0 0 0 0 0 -0.5" size="0.04"/>
                    <body name="foot_left" pos="0 0 -0.5">
                        <joint name="foot_left_joint" type="hinge" pos="0 0 0" axis="0 -1 0" range="-45 45"/>
                        <geom name="foot_left_geom" type="capsule" fromto="-0.1 0 0 0.2 0 0" size="0.06"/>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>
    
    <actuator>
        <motor joint="thigh_joint" gear="100"/>
        <motor joint="leg_joint" gear="100"/>
        <motor joint="foot_joint" gear="100"/>
        <motor joint="thigh_left_joint" gear="100"/>
        <motor joint="leg_left_joint" gear="100"/>
        <motor joint="foot_left_joint" gear="100"/>
    </actuator>
</mujoco>